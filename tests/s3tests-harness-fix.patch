+def _delete_objects_safe(client, bucket, objects):
+    """Delete objects, falling back to without BypassGovernanceRetention
+    if the bucket doesn't have Object Lock enabled."""
+    try:
+        return client.delete_objects(Bucket=bucket,
+                Delete={'Objects': objects, 'Quiet': True},
+                BypassGovernanceRetention=True)
+    except ClientError as e:
+        if 'InvalidArgument' in str(e) or 'NotImplemented' in str(e):
+            return client.delete_objects(Bucket=bucket,
+                    Delete={'Objects': objects, 'Quiet': True})
+        raise
