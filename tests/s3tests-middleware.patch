+import json
+import urllib.request
+import urllib.error
 
 config = munch.Munch
 
 # this will be assigned by setup()
 prefix = None
 
+# Middleware mode: redirect bucket create/delete through admin API
+_middleware_account_map = {}         # access_key -> account_id
+_middleware_created_buckets = {}     # bucket_name -> access_key (track ownership)
+
+def _middleware_create_bucket(name, account_id):
+    """Create bucket via S3 middleware admin API."""
+    data = json.dumps({"name": name, "account_id": account_id}).encode()
+    req = urllib.request.Request(
+        config.middleware_admin_url + '/admin/buckets',
+        data=data, method='POST',
+        headers={'Authorization': 'Bearer ' + config.middleware_admin_api_key,
+                 'Content-Type': 'application/json'})
+    try:
+        urllib.request.urlopen(req)
+    except urllib.error.HTTPError as e:
+        body = e.read().decode()
+        raise RuntimeError('middleware create bucket %s failed (%d): %s' % (name, e.code, body))
+    _middleware_created_buckets[name] = account_id
+
+def _middleware_delete_bucket(name):
+    """Delete bucket via S3 middleware admin API."""
+    req = urllib.request.Request(
+        config.middleware_admin_url + '/admin/buckets/' + name,
+        method='DELETE',
+        headers={'Authorization': 'Bearer ' + config.middleware_admin_api_key})
+    try:
+        urllib.request.urlopen(req)
+    except urllib.error.HTTPError:
+        pass
+    _middleware_created_buckets.pop(name, None)
+
+def _middleware_get_account_id(client):
+    """Map boto3 client credentials to middleware account_id."""
+    ak = client._request_signer._credentials.access_key
+    return _middleware_account_map.get(ak, config.middleware_main_account_id)
+
 def get_prefix():
     assert prefix is not None
     return prefix
